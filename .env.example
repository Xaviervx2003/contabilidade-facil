# =============================================================
# .env.example — Template seguro para variáveis de ambiente
# NUNCA coloque valores reais aqui. Este arquivo É versionado.
# Copie para .env e preencha com seus valores reais.
# =============================================================

# --- BANCO DE DADOS (Neon) ---
# Obtenha no painel: https://console.neon.tech → Connection Details
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require&channel_binding=require

# Alternativas individuais (para o backend Python)
DB_HOST=ep-your-project.sa-east-1.aws.neon.tech
DB_PORT=5432
DB_NAME=neondb
DB_USER=neondb_owner
DB_PASSWORD=SUBSTITUA_AQUI

# --- ADMIN ---
# Usado pelo script scripts/criar_admin.py
ADMIN_MATRICULA=admin
ADMIN_SENHA=SUBSTITUA_POR_SENHA_FORTE_MIN8_CHARS

# --- SCRAPER (Gran Cursos) ---
# Token JWT capturado manualmente no browser (DevTools → Network → Authorization)
GRAN_TOKEN=Bearer eyJ...

# --- BACKEND ---
PORT=8000

# --- REDIS (opcional, mas recomendado em produção) ---
# Upstash free tier: https://console.upstash.com
# Formato: redis://default:PASSWORD@HOST:PORT
REDIS_URL=redis://default:SUBSTITUA@SEU_HOST.upstash.io:6379

# --- FRONTEND (painel-admin/.env) ---
# Defina também em: Vercel → Settings → Environment Variables
VITE_API_URL=https://seu-backend.railway.app
